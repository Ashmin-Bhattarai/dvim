#!/bin/bash
# =============================================================================
# dvim — Docker Vim launcher
#
# Install:
#   curl -fsSL https://get.dvim.ashmin.info.np/install.sh | bash
#   curl -fsSL https://get.dvim.ashmin.info.np/install.sh | bash -s v1.0
#
# Usage:
#   dvim                    open nvim in current directory
#   dvim myfile.py          open specific file
#   dvim .                  open current directory explicitly
#   dvim update             pull latest image and update launcher
#
# Config:
#   ~/.config/dvim/user.lua     system-wide settings and keymaps
#   ./.dvim.lua                 project-specific settings (highest priority)
# =============================================================================

set -euo pipefail

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------
DVIM_IMAGE="${DVIM_IMAGE:-ashminbhattarai/dvim:latest}"
DVIM_CONFIG_DIR="${HOME}/.config/dvim"
DVIM_STATE_DIR="${HOME}/.local/share/dvim"
DVIM_REPO_DIR="${HOME}/.local/share/dvim/repo"
DVIM_BIN_DIR="${HOME}/.local/bin"

# -----------------------------------------------------------------------------
# Colors
# -----------------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

log()  { echo -e "${CYAN}[dvim]${RESET} $*"; }
warn() { echo -e "${YELLOW}[dvim] WARN:${RESET} $*" >&2; }
die()  { echo -e "${RED}[dvim] ERROR:${RESET} $*" >&2; exit 1; }

# -----------------------------------------------------------------------------
# update subcommand
# -----------------------------------------------------------------------------
cmd_update() {
    local tag="${1:-latest}"
    log "Pulling image ashminbhattarai/dvim:${tag}..."
    docker pull "ashminbhattarai/dvim:${tag}"

    if [ -d "${DVIM_REPO_DIR}" ]; then
        log "Updating launcher from repo..."
        git -C "${DVIM_REPO_DIR}" pull --ff-only
        install -m755 "${DVIM_REPO_DIR}/launcher/dvim" "${DVIM_BIN_DIR}/dvim"
        log "Launcher updated."
    else
        warn "Repo not found at ${DVIM_REPO_DIR} — skipping launcher update."
        warn "Re-run the install script to fix this."
    fi

    log "Update complete. Image: ashminbhattarai/dvim:${tag}"
}

# -----------------------------------------------------------------------------
# Handle subcommands
# -----------------------------------------------------------------------------
if [ "${1:-}" = "update" ]; then
    cmd_update "${2:-latest}"
    exit 0
fi

# -----------------------------------------------------------------------------
# Ensure Docker is available
# -----------------------------------------------------------------------------
if ! command -v docker &>/dev/null; then
    die "Docker is not installed or not on PATH."
fi

if ! docker info &>/dev/null; then
    die "Docker daemon is not running."
fi

# -----------------------------------------------------------------------------
# Ensure the image exists locally — pull if missing
# -----------------------------------------------------------------------------
if docker image inspect "${DVIM_IMAGE}" &>/dev/null; then
    : # image exists locally, nothing to do
else
    log "Image ${DVIM_IMAGE} not found locally. Pulling..."
    if ! docker pull "${DVIM_IMAGE}"; then
        die "Failed to pull ${DVIM_IMAGE}. If using a local image, build it first with: docker build -t ${DVIM_IMAGE} ."
    fi
fi

# -----------------------------------------------------------------------------
# Resolve absolute project path
# This ensures paths inside the container match the host exactly,
# which is critical for Python venv detection and LSP path resolution.
# -----------------------------------------------------------------------------
PROJECT_PATH="$(pwd)"

# -----------------------------------------------------------------------------
# Ensure persistent state directories exist
# -----------------------------------------------------------------------------
mkdir -p \
    "${DVIM_STATE_DIR}/state" \
    "${DVIM_STATE_DIR}/shada" \
    "${DVIM_STATE_DIR}/swap"

# -----------------------------------------------------------------------------
# Build docker run arguments
# -----------------------------------------------------------------------------
DOCKER_ARGS=(
    run
    --rm
    --interactive
    --tty

    # Mount project at SAME absolute path as host
    # e.g. /home/user/myapp → /home/user/myapp inside container
    # This ensures venv paths, LSP paths, and all absolute references match
    --volume "${PROJECT_PATH}:${PROJECT_PATH}"
    --workdir "${PROJECT_PATH}"

    # Tell entrypoint where the project is mounted
    --env "HOST_PROJECT_PATH=${PROJECT_PATH}"
)

# -----------------------------------------------------------------------------
# System-wide user config
# ~/.config/dvim/user.lua → lua/dvim/user.lua inside container
# -----------------------------------------------------------------------------
USER_CONFIG="${DVIM_CONFIG_DIR}/user.lua"
if [ -f "${USER_CONFIG}" ]; then
    DOCKER_ARGS+=(--volume "${USER_CONFIG}:/home/devuser/.config/nvim/lua/dvim/user.lua:ro")
    log "Loading user config: ${USER_CONFIG}"
fi

# -----------------------------------------------------------------------------
# Project-level config
# .dvim.lua in current dir → lua/dvim/project.lua inside container
# -----------------------------------------------------------------------------
PROJECT_CONFIG="${PROJECT_PATH}/.dvim.lua"
if [ -f "${PROJECT_CONFIG}" ]; then
    DOCKER_ARGS+=(--volume "${PROJECT_CONFIG}:/home/devuser/.config/nvim/lua/dvim/project.lua:ro")
    log "Loading project config: ${PROJECT_CONFIG}"
fi

# -----------------------------------------------------------------------------
# Persistent state mounts
#
# ~/.local/share/dvim/state → ~/.local/state/nvim   (undo, sessions)
# ~/.local/share/dvim/shada → ~/.local/share/nvim/shada (history, marks)
# ~/.local/share/dvim/swap  → ~/.local/state/nvim/swap  (swap files)
# -----------------------------------------------------------------------------
DOCKER_ARGS+=(
    --volume "${DVIM_STATE_DIR}/state:/home/devuser/.local/state/nvim"
    --volume "${DVIM_STATE_DIR}/shada:/home/devuser/.local/share/nvim/shada"
    --volume "${DVIM_STATE_DIR}/swap:/home/devuser/.local/state/nvim/swap"
)

# -----------------------------------------------------------------------------
# Image and pass-through arguments
# -----------------------------------------------------------------------------
DOCKER_ARGS+=("${DVIM_IMAGE}")

if [ "$#" -gt 0 ]; then
    DOCKER_ARGS+=("$@")
fi

# -----------------------------------------------------------------------------
# Launch
# -----------------------------------------------------------------------------
exec docker "${DOCKER_ARGS[@]}"
